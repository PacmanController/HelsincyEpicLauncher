<Page
    x:Class="Launcher.Presentation.Modules.FabLibrary.FabAssetDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Launcher.Presentation.Modules.FabLibrary"
    Background="Transparent"
    Loaded="Page_Loaded">

    <Page.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVis" />
        <local:BoolNegationToVisibilityConverter x:Key="BoolNegToVis" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ====== 顶部导航栏 ====== -->
        <Grid Grid.Row="0" Padding="36,16,36,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button
                Grid.Column="0"
                Content="&#xE72B;"
                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                FontSize="16"
                Padding="10,8"
                ToolTipService.ToolTip="返回"
                Click="BackButton_Click" />
            <TextBlock
                Grid.Column="1"
                Text="{x:Bind ViewModel.Title, Mode=OneWay}"
                Style="{StaticResource SubtitleTextBlockStyle}"
                VerticalAlignment="Center"
                Margin="12,0,0,0"
                TextTrimming="CharacterEllipsis" />
        </Grid>

        <!-- ====== 加载状态 ====== -->
        <StackPanel
            Grid.Row="1"
            Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="12">
            <ProgressRing IsActive="True" Width="40" Height="40" />
            <TextBlock Text="加载中..." Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
        </StackPanel>

        <!-- ====== 错误状态 ====== -->
        <StackPanel
            Grid.Row="1"
            Visibility="{x:Bind ViewModel.HasError, Mode=OneWay, Converter={StaticResource BoolToVis}}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="8">
            <FontIcon Glyph="&#xE783;" FontSize="48" Foreground="{ThemeResource SystemFillColorCriticalBrush}" HorizontalAlignment="Center" />
            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
            <Button Content="重试"
                    HorizontalAlignment="Center"
                    Command="{x:Bind ViewModel.LoadCommand}"
                    CommandParameter="{x:Bind ViewModel.AssetId, Mode=OneWay}" />
        </StackPanel>

        <!-- ====== 详情内容 ====== -->
        <ScrollViewer
            Grid.Row="1"
            Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolNegToVis}}"
            Padding="36,16,36,24">

            <StackPanel Spacing="24" MaxWidth="960">

                <!-- === 主视觉区：Hero 图 + 基础信息 === -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>

                    <!-- Hero 图 -->
                    <Border Grid.Column="0"
                            CornerRadius="8"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            MinHeight="300"
                            Margin="0,0,24,0">
                        <Image Source="{x:Bind ViewModel.HeroImage, Mode=OneWay}"
                               Stretch="UniformToFill"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    </Border>

                    <!-- 右侧信息面板 -->
                    <StackPanel Grid.Column="1" Spacing="12">
                        <TextBlock Text="{x:Bind ViewModel.Title, Mode=OneWay}"
                                   Style="{StaticResource TitleTextBlockStyle}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{x:Bind ViewModel.Author, Mode=OneWay}"
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <!-- 评分 -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{x:Bind ViewModel.RatingText, Mode=OneWay}"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center">
                                <Run Text="(" /><Run Text="{x:Bind ViewModel.RatingCount, Mode=OneWay}" /><Run Text=" 个评分)" />
                            </TextBlock>
                        </StackPanel>

                        <!-- 价格 -->
                        <TextBlock Text="{x:Bind ViewModel.PriceText, Mode=OneWay}"
                                   Style="{StaticResource SubtitleTextBlockStyle}" />

                        <!-- 下载按钮 -->
                        <Button
                            Content="{x:Bind ViewModel.DownloadButtonText, Mode=OneWay}"
                            Style="{StaticResource AccentButtonStyle}"
                            IsEnabled="{x:Bind ViewModel.CanDownload, Mode=OneWay}"
                            Click="DownloadButton_Click"
                            HorizontalAlignment="Stretch"
                            Padding="0,10" />

                        <!-- 元数据 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="版本" Margin="0,0,16,6"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{x:Bind ViewModel.LatestVersion, Mode=OneWay}"
                                       Style="{StaticResource CaptionTextBlockStyle}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="大小" Margin="0,0,16,6"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="{x:Bind ViewModel.DownloadSizeText, Mode=OneWay}"
                                       Style="{StaticResource CaptionTextBlockStyle}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="更新" Margin="0,0,16,0"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="{x:Bind ViewModel.UpdatedAtText, Mode=OneWay}"
                                       Style="{StaticResource CaptionTextBlockStyle}" />
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- === 描述 === -->
                <StackPanel Spacing="8">
                    <TextBlock Text="描述" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="{x:Bind ViewModel.Description, Mode=OneWay}"
                               Style="{StaticResource BodyTextBlockStyle}"
                               TextWrapping="Wrap"
                               IsTextSelectionEnabled="True" />
                </StackPanel>

                <!-- === 截图画廊 === -->
                <StackPanel Spacing="8"
                            Visibility="{x:Bind ViewModel.HasScreenshots, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="截图" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.Screenshots, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Horizontal" Spacing="12" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="local:ScreenshotItem">
                                    <Border
                                        CornerRadius="6"
                                        Width="400" Height="225"
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                        <Image Source="{x:Bind Image, Mode=OneWay}"
                                               Stretch="UniformToFill" />
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </StackPanel>

                <!-- === 兼容引擎版本 === -->
                <StackPanel Spacing="8">
                    <TextBlock Text="兼容引擎版本" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.SupportedEngineVersions, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="8" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="10,4">
                                    <TextBlock Text="{x:Bind}" Style="{StaticResource CaptionTextBlockStyle}" />
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- === 标签 === -->
                <StackPanel Spacing="8">
                    <TextBlock Text="标签" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.Tags, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="6" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border
                                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                                    CornerRadius="12"
                                    Padding="10,4">
                                    <TextBlock Text="{x:Bind}" FontSize="12" Foreground="White" />
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- === 技术细节 === -->
                <StackPanel Spacing="8"
                            Visibility="{x:Bind ViewModel.HasTechnicalDetails, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="技术细节" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="{x:Bind ViewModel.TechnicalDetails, Mode=OneWay}"
                               Style="{StaticResource BodyTextBlockStyle}"
                               TextWrapping="Wrap"
                               IsTextSelectionEnabled="True"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
